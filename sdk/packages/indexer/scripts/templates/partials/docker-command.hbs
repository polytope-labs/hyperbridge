- ${SUB_COMMAND:-}
- -f=/app/{{chainName}}.yaml
- --db-schema=app
- --workers=${SUBQL_WORKERS:-16}
- --batch-size=${SUBQL_BATCH_SIZE:-100}
- --timeout=${SUBQL_TIMEOUT:-1800}
- --multi-chain
- --disable-multichain-rewind-lock
- --unsafe
- --log-level=info
{{#if unfinalizedBlocks}}
- --historical=timestamp
{{#if blockConfirmations}}
- --block-confirmations={{blockConfirmations}}
{{else}}
- --block-confirmations=0
{{/if}}
- --unfinalized-blocks
{{else}}
- --unfinalized-blocks=false
{{/if}}
- --store-cache-async=true
