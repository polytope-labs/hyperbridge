{{> metadata}}
{{> network-config}}
{{#if chainTypesConfig}}
  chaintypes:
    file: {{chainTypesConfig}}
{{/if}}
dataSources:
  - kind: substrate/Runtime
    startBlock: {{blockNumber}}
    mapping:
      file: ./dist/index.js
      handlers:
      {{> handlers}}
{{#if isHyperbridgeChain}}
        - handler: handleRelayerRewardedEvent
          kind: substrate/EventHandler
          filter:
            module: consensusIncentives
            method: RelayerRewarded
        - handler: handleFeeRewardedEvent
          kind: substrate/EventHandler
          filter:
            module: messagingFees
            method: FeeRewarded
        - handler: handleTreasuryTransferEvent
          kind: substrate/EventHandler
          filter:
           module: balances
           method: Transfer
        - handler: handleAccumulateFeesEvent
          kind: substrate/EventHandler
          filter:
           module: relayer
           method: AccumulateFees
        - handler: handleRelayerWithdrawEvent
          kind: substrate/EventHandler
          filter:
            module: relayer
            method: Withdraw
        - handler: handleCollatorRewardedEvent
          kind: substrate/EventHandler
          filter:
            module: collatorManager
            method: CollatorRewarded
        - handler: handleBandwidthCreditedEvent
          kind: substrate/EventHandler
          filter:
            module: bandwidth
            method: BandwidthCredited
        - handler: handleBandwidthConsumedEvent
          kind: substrate/EventHandler
          filter:
            module: bandwidth
            method: BandwidthConsumed
        - handler: handleSubscriptionEvictedEvent
          kind: substrate/EventHandler
          filter:
            module: bandwidth
            method: SubscriptionEvicted
        - handler: handleForceCreditedEvent
          kind: substrate/EventHandler
          filter:
            module: bandwidth
            method: ForceCredited
        - handler: handleTierSetEvent
          kind: substrate/EventHandler
          filter:
            module: bandwidth
            method: TierSet
        - handler: handleBidPlaced
          kind: substrate/EventHandler
          filter:
            module: intentsCoprocessor
            method: BidPlaced
        - handler: handleBridgeTokenSupplyIndexing
          kind: substrate/BlockHandler
          filter:
            modulo: 3600 # Indexings 1 block every 6 hours (6 seconds per block indexing).
{{/if}}
{{#if enablePriceIndexing}}
        - handler: handlePriceIndexing
          kind: substrate/BlockHandler
          filter:
            modulo: 10 # Indexings 1 block every minute (6 seconds per block indexing).
        - handler: handlePhantomOrderRegistered
          kind: substrate/EventHandler
          filter:
            module: intentsCoprocessor
            method: PhantomOrderRegistered
        - handler: handlePhantomOrderPrices
          kind: substrate/EventHandler
          filter:
            module: intentsCoprocessor
            method: PhantomBidWindowExhausted
{{/if}}
        - handler: handlePendingStatusFlush
          kind: substrate/BlockHandler
          filter:
            modulo: 10 # Each chain instance flushes its own pending writes — historical filter hides cross-chain rows.

repository: 'https://github.com/polytope-labs/hyperbridge'
